datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserStatus {
  PENDING
  ACTIVE
  LOCKED
  BANNED
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id                 Int                 @id @default(autoincrement())
  email              String              @unique
  displayName        String
  passwordHash       String
  status             String              @default("PENDING")
  balance            Int                 @default(0)
  role               UserRole            @default(USER)
  walletTransactions WalletTransaction[]
  createdAt          DateTime            @default(now())

  // ĐẢM BẢO CÓ ĐỦ 4 DÒNG KHAI BÁO MỐI QUAN HỆ NÀY:
  authLogs      AuthLog[] // Giữ nguyên dòng cũ của bạn (nếu có)
  deposits      Deposit[] // Khớp với model Deposit ở dưới
  orders        Order[] // Khớp với model Order ở dưới
  globalNotificationReads GlobalNotificationRead[]
  notifications Notification[] // Khớp với model Notification ở dưới
}

// Định nghĩa Enum cho các loại biến động số dư
enum TransactionType {
  DEPOSIT // Nạp tiền
  BUY // Mua hàng
  ADMIN_INCREMENT // Admin cộng tiền
  ADMIN_DECREMENT // Admin trừ tiền
}

// Bảng Nhật ký giao dịch ví (wallet_transactions)
model WalletTransaction {
  id     Int  @id @default(autoincrement())
  userId Int  @map("user_id")
  user   User @relation(fields: [userId], references: [id])

  type          TransactionType // Loại giao dịch
  amount        Int // Số tiền biến động (Luôn lưu số dương, phân biệt tăng giảm qua `type`)
  balanceBefore Int             @map("balance_before") // Số dư TRƯỚC khi đổi
  balanceAfter  Int             @map("balance_after") // Số dư SAU khi đổi

  referenceId String? @map("reference_id") // Mã đơn nạp (DEPxxx) hoặc mã đơn hàng (ORDxxx)
  description String? // Lý do biến động (Khuyến mãi, Mua Facebook VIA...)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("wallet_transactions")
}

model AuthLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  action    String // REGISTER, LOGIN_SUCCESS, LOGIN_FAIL
  ip        String
  userAgent String
  country   String   @default("Unknown")
  device    String   @default("Unknown")
  createdAt DateTime @default(now())
}

// 1. Model Lịch sử nạp tiền
model Deposit {
  id          Int      @id @default(autoincrement())
  userId      Int
  amount      Int      @default(0) // Số tiền hệ thống nhận được thực tế (hoặc dự kiến)
  method      String // BANKING, MOMO...
  status      String   @default("PENDING") // PENDING, SUCCESS, EXPIRED
  description String   @unique // Lưu mã nạp tiền duy nhất (Ví dụ: DEP-7XQ8K2)
  bankTxId    String?  @unique // MÃ GIAO DỊCH NGÂN HÀNG (Ví dụ: 2026070800003988504). Rất quan trọng để CHỐNG CỘNG TIỀN 2 LẦN
  expiredAt   DateTime // Thời gian hết hạn lệnh nạp (now + 10 phút)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([description])
  @@map("deposits")
}

// 2. Model Lịch sử mua hàng
model Order {
  id            String      @id @default(uuid()) // Chuyển sang UUID
  orderCode     String      @unique @map("order_code") // Mã đơn hiển thị (VD: ORD-260001)
  userId        Int         @map("user_id")
  totalAmount   Int         @map("total_amount")
  totalQuantity Int         @map("total_quantity")
  status        OrderStatus @default(PENDING)
  paymentMethod String      @default("WALLET") @map("payment_method")
  createdAt     DateTime    @default(now()) @map("created_at")
  completedAt   DateTime?   @map("completed_at")

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items    OrderItem[]
  accounts OrderAccount[]

  @@map("orders")
}

model OrderItem {
  id          String @id @default(uuid())
  orderId     String @map("order_id")
  productId   Int    @map("product_id")
  productName String @map("product_name") // Lưu tên tại thời điểm mua
  quantity    Int
  unitPrice   Int    @map("unit_price") // Giá tại thời điểm mua
  totalPrice  Int    @map("total_price")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model OrderAccount {
  id          String   @id @default(uuid())
  orderId     String   @map("order_id")
  accountData String   @map("account_data") @db.Text // Thông tin clone/via giao cho khách
  createdAt   DateTime @default(now()) @map("created_at") // Phục vụ cronjob xóa sau 30 ngày

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_accounts")
}

// 3. Model Hệ thống Thông báo (Notification)
model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int?     // Đổi thành Int? (cho phép null) để dùng cho thông báo Toàn hệ thống
  title     String   // Tiêu đề thông báo
  content   String   @db.Text // Nội dung thông báo
  isRead    Boolean  @default(false) // Trạng thái đã đọc (chỉ áp dụng cho thông báo cá nhân)
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  //Thêm quan hệ này để lưu trạng thái khi user đọc thông báo Global
  globalReads GlobalNotificationRead[]

  @@map("notifications")
}

// 👉 Bảng phụ lưu vết User nào đã đọc thông báo Toàn hệ thống nào (Tránh phình to DB)
model GlobalNotificationRead {
  id             Int      @id @default(autoincrement())
  notificationId Int      @map("notification_id")
  userId         Int      @map("user_id")
  readAt         DateTime @default(now())

  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@map("global_notification_reads")
}

// 4. Model Quản lý Voucher (Mã giảm giá)
model Voucher {
  id         Int      @id @default(autoincrement())
  code       String   @unique // Mã giảm giá (VÍ DỤ: GIAM20K)
  discount   Int // Số tiền được giảm hoặc phần trăm
  type       String   @default("FIXED") // FIXED (trừ thẳng tiền) hoặc PERCENT (giảm %)
  maxUses    Int      @default(1) // Số lần sử dụng tối đa của mã này
  usedCount  Int      @default(0) // Số lần đã được sử dụng
  expiryDate DateTime // Ngày hết hạn mã
  createdAt  DateTime @default(now())

  @@map("vouchers")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    Int? // Sửa lại thành Int cho đồng bộ với kiểu dữ liệu id của model User (User id là Int)
  action    String
  module    String
  ipAddress String?
  userAgent String?
  oldValues Json?
  newValues Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@map("audit_logs") // <-- THÊM DÒNG NÀY ĐỂ ÉP TÊN BẢNG VIẾT THƯỜNG
}

enum CategoryStatus {
  ACTIVE
  INACTIVE
}

model Category {
  id           Int            @id @default(autoincrement())
  name         String         @db.VarChar(255)
  description  String?        @db.Text
  icon         String?        @db.VarChar(255) // Lưu đường dẫn file icon (vd: /uploads/icons/facebook.png)
  avatar       String?        @db.VarChar(255) // Lưu đường dẫn ảnh đại diện
  displayOrder Int            @default(0) // Thứ tự hiển thị (số nhỏ xếp trước)
  status       CategoryStatus @default(ACTIVE)

  // Các trường cấu hình SEO
  seoTitle       String? @db.VarChar(255)
  seoDescription String? @db.Text
  seoKeywords    String? @db.VarChar(255)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Quan hệ: Một danh mục có nhiều sản phẩm
  products Product[]

  @@map("categories")
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

model Product {
  id          Int           @id @default(autoincrement())
  categoryId  Int
  name        String        @db.VarChar(255)
  slug        String        @unique @db.VarChar(255) // Phục vụ SEO (Vd: facebook-via-2018)
  price       Int           @default(0)
  description String?       @db.Text // Mô tả dạng HTML text
  status      ProductStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Quan hệ
  category   Category    @relation(fields: [categoryId], references: [id])
  accounts   Account[] // Kho tài khoản thuộc sản phẩm này
  orderItems OrderItem[]

  @@map("products")
}

enum AccountStatus {
  AVAILABLE // Có thể bán
  RESERVED // Đang có người mua (Tạm giữ)
  SOLD // Đã bán
  DISABLED // Ẩn/Lỗi không bán
}

model Account {
  id          Int           @id @default(autoincrement())
  productId   Int
  accountData String        @db.Text
  status      AccountStatus @default(AVAILABLE) // AVAILABLE là còn hàng, SOLD là đã bán
  orderId     Int?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  product     Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

enum OrderStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}
